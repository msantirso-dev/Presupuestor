# Copiar a .env y completar. Neon: Dashboard → Connect.
# DATABASE_URL: endpoint -pooler (PgBouncer) para la app.
# DATABASE_URL_UNPOOLED: sin pooler; Prisma lo usa para migrate/db push.
# Las tablas de esta app viven en el esquema PostgreSQL "presupuestor" (no en public),
# para poder compartir el mismo neondb con otras apps sin pisar sus tablas.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"
